{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Firestore Task Document",
  "type": "object",
  "properties": {
    "title": {
      "type": "string"
    },
    "details": {
      "type": "string"
    },
    "completed": {
      "type": "boolean"
    },
    "created": {
      "type": "string",
      "format": "date-time",
      "description": "Task creation timestamp"
    },
    "user": {
      "type": "string",
      "description": "Firestore document reference path to the owning user",
      "pattern": "^/users/[A-Za-z0-9]+$"
    }
  },
  "required": [
    "title",
    "completed",
    "created",
    "user"
  ],
  "additionalProperties": false
}
